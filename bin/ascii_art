import sys
from pathlib import Path
from datetime import datetime

sys.path.insert(0, str(Path(__file__).resolve().parent.parent / "src"))

from ascii_art.parse_args import parse_args, validate_args
from ascii_art.load_img import load_img
from ascii_art.convert import convert_img_to_ascii_art

def make_python_script(ascii_art) -> str:
    escaped: list[str] = list(
        ascii_art
        .replace('\033', '\\033')
        .splitlines()
    )

    return (
        f"# Generated by ascii_art @ {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n"
        "escaped: tuple[str, ...] = (\n"
        + ",\n".join(f'    "{e}"' for e in escaped)
        + "\n)\n\n"
        + 'if __name__ == "__main__":\n'
        f'    print("\\n".join(escaped))\n'
    )

def main():
    args = parse_args()
    validate_args(args)

    img = load_img(args.input)
    ascii_art = convert_img_to_ascii_art(img, small=args.small, mode=args.mode)

    py_script = make_python_script(ascii_art)
    args.output.write_text(py_script, encoding="utf-8")

    print(f"Script generation completed at '{args.output}'\n")
    print(ascii_art)

if __name__ == "__main__":
    main()
